{
  "name": "@hk9890/opencode-coder",
  "version": "0.14.0",
  "description": "OpenCode plugin for story-driven development with agents and commands",
  "author": "hk9890",
  "repository": {
    "type": "git",
    "url": "https://github.com/hk9890/opencode-coder.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "dist/opencode-coder.js",
  "types": "dist/opencode-coder.d.ts",
  "exports": {
    ".": {
      "types": "./dist/opencode-coder.d.ts",
      "import": "./dist/opencode-coder.js"
    }
  },
  "files": [
    "dist",
    "knowledge-base"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/opencode-coder.js --target bun",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e --timeout 60000",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "typecheck": "bun x tsc --noEmit",
    "opencode:dev": "bun run build && opencode --log-level DEBUG",
    "logs": "bun run scripts/log-analyzer/index.ts",
    "logs:processes": "bun run scripts/log-analyzer/index.ts list processes",
    "logs:sessions": "bun run scripts/log-analyzer/index.ts list sessions"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "coding-assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.207",
    "mustache": "^4.2.0",
    "yaml": "^2.7.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/mustache": "^4.2.6",
    "typescript": "^5.7.2"
  }
}
