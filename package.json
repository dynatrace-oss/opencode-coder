{
  "name": "opencode-coder",
  "version": "0.1.0",
  "description": "OpenCode plugin for story-driven development with agents and commands",
  "type": "module",
  "main": "dist/opencode-coder.js",
  "types": "dist/opencode-coder.d.ts",
  "exports": {
    ".": {
      "types": "./dist/opencode-coder.d.ts",
      "import": "./dist/opencode-coder.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/opencode-coder.js --target bun",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist",
    "typecheck": "bun x tsc --noEmit",
    "mtest": "bun run build && cd manual-test && opencode --print-logs --log-level DEBUG",
    "qtest": "bun run build && cd manual-test && opencode --print-logs run hallo"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "coding-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.185"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
